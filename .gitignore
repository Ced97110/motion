# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# caches + ephemeral outputs
.cache/
/test-results/
/playwright-report/
/scripts/.resynth-manifest.json
/scripts/.page-offsets.json
/scripts/.gap-concept-analysis.ts
/scripts/.gap-concept-analysis.json

# copyrighted source material — PDFs are NOT redistributable; wiki/*.md
# derived content is versioned but raw PDFs stay local-only
/knowledge-base/raw/

# compounding-query-capture patch queue — per-coach query traffic stays
# local; only the directory contract (README) is versioned.
/knowledge-base/wiki/_pending/*
!/knowledge-base/wiki/_pending/README.md

# large pipeline output (61MB) — regenerate with scripts/02_parse_dataset.py
# from the SportsSettBasketball source. See spec/SPORTSETT_INTEGRATION.md.
/data/parsed_games.json

# dev-only symlink to sibling backend's wiki (post FE/BE split). Keeps the
# TS scripts in scripts/*.ts working via their historical relative paths
# without a 12-file refactor. For CI/production that doesn't have
# backend/ as a sibling, set MOTION_WIKI_DIR (see src/lib/wiki-loader.ts).
/knowledge-base
